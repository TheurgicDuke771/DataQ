# Copy to terraform.tfvars (gitignored) and fill in. Every value here is
# NON-SECRET (identifiers + sizing). No passwords/tokens — those are generated by
# Terraform (random_password) or set as repo secrets post-apply. Leaving this file
# empty is fine: the variable defaults already target the v1 single-tenant deploy.

# image_tag = "v1"                 # bump per deploy (immutable tag, not "latest")

# Azure AD SSO (fill once the app registrations exist; empty deploys fine with
# health/docs reachable — AUTH_DEV_BYPASS stays false regardless).
# azure_tenant_id     = "00000000-0000-0000-0000-000000000000"
# azure_api_client_id = "00000000-0000-0000-0000-000000000000"
# azure_spa_client_id = "00000000-0000-0000-0000-000000000000"

# workspace_admin_emails = "you@example.com"

# github_repo        = "TheurgicDuke771/DataQ"
# github_environment = "production"
