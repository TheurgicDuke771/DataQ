{
  "$schema": "https://json.schemastorage.azurewebsites.net/schemas/2021-08-01/staticwebapp.config.json",
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/assets/*", "*.{css,js,png,svg,ico,woff,woff2}"]
  },
  "responseOverrides": {
    "404": { "rewrite": "/index.html" }
  }
}
