htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# Alembic
alembic/versions/__pycache__/

# ---- Node / Frontend ----
node_modules/
# pnpm content-addressable store (compose frontend keeps it in a volume; this is
