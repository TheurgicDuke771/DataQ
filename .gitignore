.pnpm-store/
.pnp/
.pnp.js
dist/
dist-ssr/
build/
.vite/
.next/
.nuxt/
.cache/
.parcel-cache/
*.tsbuildinfo
.eslintcache
.stylelintcache

# Vitest / Jest
coverage/

# Playwright (browser E2E artifacts + downloaded browsers)
frontend/test-results/
frontend/playwright-report/
frontend/playwright/.cache/

# ---- Environment / secrets ----
.env
.env.*
.envrc
!.env.example
!.env.app.example
# Prod env *reference* (blank secret values, like the dev example above).
!deploy/.env.app.prod.example
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
.secrets/
credentials.json

# ---- Docker ----
.docker/
docker-compose.override.yml
*.pid

# ---- IDE / Editor ----
# Ignore everything in .vscode/ EXCEPT the shared team files.
# (Negating a parent directory's ignore is impossible in gitignore;
# must ignore-children-then-negate-specific-files instead.)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json
.idea/
*.iml
*.swp
*.swo
*~
.project
.classpath
.settings/

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
.AppleDouble
.LSOverride

# ---- Logs ----
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Local data / scratch ----
*.sqlite
*.sqlite3
*.db
local-data/
scratch/
tmp/
.tmp/

# ---- Azure / cloud creds ----
.azure/
azure.json

# ---- Terraform (deploy/terraform/<cloud>/ — azure/ today; aws/, gcp/ post-v1) ----
# State holds the generated Postgres password + secret values — never commit it.
# The provider lock (.terraform.lock.hcl) and *.example ARE tracked. Rules are
# path-independent globs, so they apply under any deploy/terraform/<cloud>/ dir.
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
# Plan output is secret-bearing (embeds resolved sensitive values) — never commit.
tfplan
*.tfplan
*.plan
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ---- Claude / agent scratch (project-local) ----
.claude/cache/
.claude/scheduled_tasks.lock

# ---- Local working-plan scratch (per-developer, never committed) ----
*_TODO.md
*.todo.local.md

# ---- Entire CLI (per-repo machine-local session data) ----
.entire/

# ---- Mutmut (mutation testing) artifacts ----
# 3.x copies the tree into ./mutants/ and runs there; .mutmut-cache is the 2.x cache.
mutants/
.mutmut-cache

# Stryker (frontend mutation spike) — sandbox + reports, never committed
frontend/.stryker-tmp/
frontend/reports/mutation/

# Playwright MCP screenshot/snapshot artifacts
.playwright-mcp/

# MkDocs build output (docs site, #288)
site/
