.pnpm-store/
.pnp/
.pnp.js
dist/
dist-ssr/
build/
.vite/
.next/
.nuxt/
.cache/
.parcel-cache/
*.tsbuildinfo
.eslintcache
.stylelintcache

# Vitest / Jest
coverage/

# Playwright (browser E2E artifacts + downloaded browsers)
frontend/test-results/
frontend/playwright-report/
frontend/playwright/.cache/

# ---- Environment / secrets ----
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
.secrets/
credentials.json

# ---- Docker ----
.docker/
docker-compose.override.yml
*.pid

# ---- IDE / Editor ----
# Ignore everything in .vscode/ EXCEPT the shared team files.
# (Negating a parent directory's ignore is impossible in gitignore;
# must ignore-children-then-negate-specific-files instead.)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json
.idea/
*.iml
*.swp
*.swo
*~
.project
.classpath
.settings/

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
.AppleDouble
.LSOverride

# ---- Logs ----
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Local data / scratch ----
*.sqlite
*.sqlite3
*.db
local-data/
scratch/
tmp/
.tmp/

# ---- Azure / cloud creds ----
.azure/
azure.json

# ---- Claude / agent scratch (project-local) ----
.claude/cache/
.claude/scheduled_tasks.lock

# ---- Entire CLI (per-repo machine-local session data) ----
.entire/

# ---- Mutmut (mutation testing) cache ----
.mutmut-cache
